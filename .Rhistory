library(readxl)
library(dplyr)
setwd("~/cobre/Cobre")
Datos <- read_excel("BD Cobre.xlsx",col_names = TRUE)
summary (Datos)
install.packages("corrplot")
library(corrplot)
install.packages("corrplot")
#Paso variables a numeric
Datos <- Datos %>%
mutate(across(-c(id, Medio, Inoculo), as.numeric))
View(Datos)
View(Datos)
Dvivo <- Datos%>% filter(Medio == "In vivo")
VRVivo <- Datos[, c("Pvastago", "PRaiz", "CuVástago", "CuRaiz",
"PSuelo", "BCTallo", "FT", "CuSuelo",
"BCRaiz", "Fe", "gt", "gfe")]
corrplot(cor_mat,
method = "color",
type = "upper",
addCoef.col = "black",  # muestra valores
tl.col = "black",
tl.srt = 45)
corrplot(VRVivo,
method = "color",
type = "upper",
addCoef.col = "black",  # muestra valores
tl.col = "black",
tl.srt = 45)
#matriz de correlacion
cor_VRVivo <- cor(VRVivo, use = "complete.obs", method = "pearson")
corrplot(cor_VRVivo,
method = "color",
type = "upper",
addCoef.col = "black",  # muestra valores
tl.col = "black",
tl.srt = 45)
