cols = c(MicelioMM, MicelioS, EsporasMM, EsporasS),
names_to = c(".value", "Seccion"),
names_pattern = "(Micelio|Esporas)(MM|S)",
select(id, Medio, Inoculo, Cu, Seccion, Micelio, Esporas))
Dvitro_MMS <- DvitroInc %>%
pivot_longer(
cols = c(MicelioMM, MicelioS, EsporasMM, EsporasS),
names_to = c(".value", "Seccion"),
names_pattern = "(Micelio|Esporas)(MM|S)")%>%
select(id, Medio, Inoculo, Cu, Seccion, Micelio, Esporas)
## Relativizado por muestra
library(ggplot2)
ggplot(Dvitro_largo, aes(x = Inoculo, y = Esporas, fill = Seccion)) +
geom_bar(stat = "identity", position = "fill") +
scale_y_continuous(labels = scales::percent) + # Cambia el eje Y a porcentaje
theme_minimal() +
labs(title = "DistribuciĂłn Relativa de Esporas",
x = "InĂłculo",
y = "Porcentaje del Total",
fill = "SecciĂłn")
View(Dvitro_MMS)
